# AI Screen Code Environment Variables Template
# Copy this file to .env and fill in your values

# =====================
# JWT Configuration
# =====================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION_DAYS=7

# =====================
# Server Configuration
# =====================
SERVER_HOST=0.0.0.0
SERVER_PORT=6247

# =====================
# OAuth Configuration (Get from respective platforms)
# =====================
# QQ OAuth - https://connect.qq.com/
QQ_CLIENT_ID=your_qq_app_id
QQ_CLIENT_SECRET=your_qq_app_secret
QQ_REDIRECT_URI=https://your-domain.com/auth/callback/qq

# WeChat OAuth - https://open.weixin.qq.com/
WECHAT_CLIENT_ID=your_wechat_appid
WECHAT_CLIENT_SECRET=your_wechat_appsecret
WECHAT_REDIRECT_URI=https://your-domain.com/auth/callback/wechat

# Douyin OAuth - https://open.douyin.com/
DOUYIN_CLIENT_ID=your_douyin_client_key
DOUYIN_CLIENT_SECRET=your_douyin_client_secret
DOUYIN_REDIRECT_URI=https://your-domain.com/auth/callback/douyin

# =====================
# Database (if using external database)
# =====================
DATABASE_URL=postgresql://user:password@localhost:5432/aiscreencodedb

# =====================
# Email Configuration
# =====================
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=your-email@qq.com
SMTP_FROM_NAME=AI Screen Code

# =====================
# AI Model API Keys
# =====================
# Qwen (Alibaba Cloud) - https://dashscope.console.aliyun.com/
QWEN_API_KEY=your_qwen_api_key

# MiniMax - https://platform.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key

# Kimi (Moonshot) - https://platform.moonshot.cn/
KIMI_API_KEY=your_kimi_api_key

# GLM (Zhipu) - https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key

# =====================
# Frontend Configuration
# =====================
VITE_API_BASE_URL=https://your-domain.com/api

# =====================
# Docker Deployment Configuration
# =====================
# Docker registry (docker.io, ghcr.io, your private registry)
DOCKER_REGISTRY=docker.io

# Image prefix (e.g., your-dockerhub-username/ai-screen-code)
IMAGE_PREFIX=your-dockerhub-username/ai-screen-code

# Image tag (use specific version or 'latest')
IMAGE_TAG=latest

# Namespace (usually your dockerhub username or organization)
NAMESPACE=your-dockerhub-username

# =====================
# SSL Configuration
# =====================
# SSL 证书路径
# 本地开发: ./ssl
# 阿里云服务器: /opt/ai-screen-code/ssl
SSL_PATH=/opt/ai-screen-code/ssl